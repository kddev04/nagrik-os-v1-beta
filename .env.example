# ══════════════════════════════════════════════════════
# NAGRIK OS BACKEND · ENVIRONMENT VARIABLES
# Copy this file to .env and fill in all values
# NEVER commit .env to Git
# ══════════════════════════════════════════════════════

# ── SERVER ──────────────────────────────────────────
NODE_ENV=development                        # development | production
PORT=3000                                   # Local dev port
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000   # Comma-separated, no trailing slash

# ── DATABASE ────────────────────────────────────────
# Option A: Full connection string (Railway/Render provide this)
DATABASE_URL=postgresql://user:password@host:5432/nagrik_db

# Option B: Individual components (if not using connection string)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=nagrik_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# ── JWT ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_64_CHAR_HEX_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_ANOTHER_64_CHAR_HEX_SECRET_HERE
JWT_ACCESS_EXPIRY=1h                        # Access token: 1 hour
JWT_REFRESH_EXPIRY=30d                      # Refresh token: 30 days

# ── OTP SETTINGS ────────────────────────────────────
OTP_EXPIRY_MINUTES=5                        # OTP valid for 5 minutes
OTP_MAX_ATTEMPTS=3                          # Block after 3 wrong attempts
OTP_RATE_LIMIT_WINDOW=900000               # 15 minutes in ms
OTP_RATE_LIMIT_MAX=3                        # Max 3 OTP sends per window

# ── EMAIL (Resend.com — Free: 3K emails/day) ────────
# Sign up at: https://resend.com → API Keys → Create Key
EMAIL_PROVIDER=resend                       # resend | smtp
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE
EMAIL_FROM=noreply@nagrikos.in             # Must be verified domain in Resend
EMAIL_FROM_NAME=Nagrik OS

# ── EMAIL (SMTP alternative — Gmail/Outlook) ────────
# Only needed if EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=your_app_specific_password    # Gmail: 16-char app password

# ── SMS (Fast2SMS — India, cheapest) ───────────────
# Sign up at: https://www.fast2sms.com → Dev API
# Free: 300 SMS on signup. Paid: ₹0.10/SMS
SMS_PROVIDER=fast2sms                      # fast2sms | twilio | disabled
FAST2SMS_API_KEY=YOUR_FAST2SMS_API_KEY_HERE

# ── SMS (Twilio — international) ───────────────────
# Free trial: $15.50 credit (~600 SMS)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── CLOUDINARY (Photo storage — Free: 25GB) ─────────
# Sign up at: https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=nagrik-os-grievances     # Folder in Cloudinary

# ── ADMIN ───────────────────────────────────────────
ADMIN_SECRET=STRONG_RANDOM_SECRET_FOR_ADMIN_ROUTES   # Used to create first admin
